# ─── GoLogin (or analogue) ─────────────────────────────────────
# Get this from your GoLogin account: https://app.gologin.com/personalArea/TokenApi
# Free trial works. Multilogin / AdsPower also work — adapt browser.js to your SDK.
GOLOGIN_API_TOKEN=your-gologin-api-token

# ─── Google service account ────────────────────────────────────
# 1) Create a GCP project + enable Sheets API
# 2) Create a service account, download its JSON key
# 3) Path to that JSON below (use absolute path; ~ is expanded)
# 4) Share your target sheet with the service account email (Editor access)
GOOGLE_SA_KEY_PATH=~/.smm-analytics-sa.json

# ─── Output Google Sheet ───────────────────────────────────────
# The ID is the long string in the sheet URL between /d/ and /edit
# https://docs.google.com/spreadsheets/d/<THIS>/edit
SHEET_ID=your-sheet-id-here

# ─── GoLogin browser profile IDs ───────────────────────────────
# Each profile = one logged-in browser session in GoLogin (LinkedIn or X).
# You can use the same profile for both if it has both sites logged in.
LINKEDIN_PROFILE_ID=your-gologin-profile-id
TWITTER_PROFILE_ID=your-gologin-profile-id

# ─── Profile handles to scrape ─────────────────────────────────
# LinkedIn: the part after /in/ in your profile URL
LINKEDIN_USERNAME=your-linkedin-handle
# X: handle without the @
TWITTER_USERNAME=your-x-handle

# ─── Your target audience ──────────────────────────────────────
# Comma-separated list of segment ids you care about.
# These IDs must match what you put in the "Segments" tab of your Sheet.
# % Target Audience column is computed against this list.
MY_TARGETS=Founder,Engineer,Designer
