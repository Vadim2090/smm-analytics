{
  "name": "smm-analytics",
  "version": "0.1.0",
  "description": "Free, self-hosted SMM analytics — track LinkedIn + X engagement segmented by audience type",
  "type": "module",
  "main": "src/index.js",
  "license": "MIT",
  "homepage": "https://github.com/Vadim2090/smm-analytics",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vadim2090/smm-analytics.git"
  },
  "bugs": {
    "url": "https://github.com/Vadim2090/smm-analytics/issues"
  },
  "author": "Vadim Smirnov",
  "keywords": [
    "linkedin",
    "twitter",
    "x",
    "analytics",
    "smm",
    "social-media",
    "marketing",
    "puppeteer",
    "gologin",
    "audience-segmentation"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/index.js",
    "linkedin": "node src/index.js --platform linkedin",
    "twitter": "node src/index.js --platform twitter",
    "backfill": "node src/index.js --backfill",
    "backfill:linkedin": "node src/index.js --backfill --platform linkedin",
    "backfill:twitter": "node src/index.js --backfill --platform twitter",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "gologin": "^2.2.8",
    "googleapis": "^144.0.0"
  }
}
